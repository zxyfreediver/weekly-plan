# 周记清单环境变量示例
#
# 使用方式：
# 1. 复制本文件为 `.env.local`
# 2. 在 Supabase Dashboard 创建项目后填入以下值

# 登录账号（AUTH_USERNAME 作为 user_id 隔离数据）
AUTH_USERNAME=your-username

# 登录密码
AUTH_PASSWORD=your-strong-password

# Supabase（从 Dashboard -> Settings -> API 获取）
# Project URL 格式：https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Service Role Key（Secret keys 区域，格式为 sb_secret_xxx 或 JWT）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx


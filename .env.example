# 周记清单环境变量示例
#
# 使用方式：
# 1. 复制本文件为 `.env.local`
# 2. 在 Supabase Dashboard 创建项目后填入以下值

# 站点 URL（可选，用于 SEO、sitemap、robots，部署后填写如 https://your-domain.com）
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 登录账号（AUTH_USERNAME 作为 user_id 隔离数据，需与 migration 中默认用户 id 一致）
AUTH_USERNAME=admin

# 登录密码
AUTH_PASSWORD=your-strong-password

# Supabase（从 Dashboard -> Settings -> API 获取）
# Project URL 格式：https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Service Role Key（Secret keys 区域，格式为 sb_secret_xxx 或 JWT）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# DeepSeek API Key（用于 AI 总结，从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

